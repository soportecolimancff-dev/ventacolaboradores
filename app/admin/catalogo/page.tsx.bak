/**
 * app/admin/catalogo/page.tsx  →  /admin/catalogo
 * Gestión del catálogo semanal: productos por sucursal con precio y stock.
 */
import { prisma } from "@/lib/prisma";
import { getMondayUTC } from "@/lib/validaciones";
import CatalogoManager from "@/components/admin/CatalogoManager";

export const metadata = { title: "Catálogo | Admin Coliman" };

export default async function AdminCatalogoPage() {
  const semana = getMondayUTC();

  const [items, productos, sucursales] = await Promise.all([
    prisma.productoSucursal.findMany({
      where: { semana },
      include: {
        producto: { select: { id: true, nombre: true, imagenUrl: true } },
        sucursal: { select: { id: true, nombre: true, slug: true } },
      },
      orderBy: [{ sucursal: { nombre: "asc" } }, { producto: { nombre: "asc" } }],
    }),
    prisma.producto.findMany({
      select: { id: true, nombre: true, unidad: true, imagenUrl: true, activo: true },
      orderBy: { nombre: "asc" },
    }),
    prisma.sucursal.findMany({
      where: { activa: true },
      select: { id: true, nombre: true, slug: true },
      orderBy: { nombre: "asc" },
    }),
  ]);

  // Serializar Decimal → number para el cliente
  const itemsSerial = items.map((i: (typeof items)[number]) => ({
    ...i,
    precio: Number(i.precio),
    stock: i.stock,
  }));

  return (
    <div className="space-y-6">
      <div>
        <h1 className="text-2xl font-extrabold text-gray-900">Catálogo semanal</h1>
        <p className="text-sm text-gray-400">
          Semana del {semana.toISOString().slice(0, 10)} · Configura los productos
          disponibles por sucursal.
        </p>
      </div>

      <CatalogoManager
        items={itemsSerial}
        productos={productos}
        sucursales={sucursales}
        semana={semana.toISOString()}
      />
    </div>
  );
}
