// Coliman – Venta de Fruta a Colaboradores
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// SUCURSAL
// ─────────────────────────────────────────────
model Sucursal {
  id        Int      @id @default(autoincrement())
  nombre    String   @unique
  slug      String   @unique           // mexicali-abastos | mexicali-centro | tijuana-ermita | ensenada
  activa    Boolean  @default(true)
  createdAt DateTime @default(now())

  productos  ProductoSucursal[]
  pedidos    Pedido[]
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────
enum UnidadVenta {
  Pz
  Kg
}

// ─────────────────────────────────────────────
// PRODUCTO (catálogo maestro)
// ─────────────────────────────────────────────
model Producto {
  id               Int         @id @default(autoincrement())
  nombre           String
  unidad           UnidadVenta @default(Pz)
  imagenUrl        String?
  maxCantidad      Int         @default(5)    // Máximo de kg/piezas por pedido (igual para todas las sucursales)
  cantidadPorCaja  Float       @default(1)    // Kilos o piezas que conforman una caja del producto
  activo           Boolean     @default(true)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  sucursales  ProductoSucursal[]
  itemsPedido ItemPedido[]
}

// ─────────────────────────────────────────────
// PRODUCTO × SUCURSAL  (catálogo semanal por ruta)
// Cada semana el admin activa / configura los productos por sucursal.
// El límite de cantidad viene del Producto maestro (global).
// ─────────────────────────────────────────────
model ProductoSucursal {
  id           Int      @id @default(autoincrement())
  productoId   Int
  sucursalId   Int
  semana       DateTime                // Lunes de la semana en curso (00:00 UTC)
  precio       Decimal  @db.Decimal(10, 2)
  stock        Int      @default(0)    // Unidades disponibles (0 = sin límite de stock)
  disponible   Boolean  @default(true)

  producto Producto @relation(fields: [productoId], references: [id])
  sucursal Sucursal @relation(fields: [sucursalId], references: [id])

  @@unique([productoId, sucursalId, semana])
}

// ─────────────────────────────────────────────
// LÍMITE DE COMPRA (global — aplica igual a todas las sucursales)
// Se pueden definir uno o ambos topes por semana:
//   montoMaximo  → tope en pesos  (ej. $300)
//   cantidadMaxima → tope en piezas/kg (ej. 10 kg en total)
// ─────────────────────────────────────────────
model LimiteCompra {
  id              Int      @id @default(autoincrement())
  semana          DateTime @unique           // Lunes de la semana en curso
  montoMaximo     Decimal? @db.Decimal(10, 2)  // Opcional: tope en pesos
  cantidadMaxima  Int?                          // Opcional: tope total en piezas/kg
  comprasAbiertas Boolean  @default(true)     // Si false, no se pueden crear pedidos esta semana
  createdAt       DateTime @default(now())
}

// ─────────────────────────────────────────────
// PEDIDO
// Los datos del colaborador se capturan al momento del pedido,
// sin necesidad de registro previo en el sistema.
// ─────────────────────────────────────────────
model Pedido {
  id              Int          @id @default(autoincrement())
  noEmpleado      String                    // Número interno de la empresa
  nombreEmpleado  String                    // Nombre capturado al confirmar
  emailEmpleado   String?                   // Correo opcional para notificaciones
  sucursalId      Int
  semana          DateTime                  // Lunes de la semana en que se realizó
  total           Decimal      @db.Decimal(10, 2)
  estado          EstadoPedido @default(PENDIENTE)
  notas           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  sucursal Sucursal    @relation(fields: [sucursalId], references: [id])
  items    ItemPedido[]

  // Un colaborador solo puede tener UN pedido por sucursal por semana
  @@unique([noEmpleado, sucursalId, semana])
}

// ─────────────────────────────────────────────
// ÍTEM DE PEDIDO
// ─────────────────────────────────────────────
model ItemPedido {
  id          Int     @id @default(autoincrement())
  pedidoId    Int
  productoId  Int
  cantidad    Int
  precioUnit  Decimal @db.Decimal(10, 2)  // Precio snapshot al momento del pedido
  subtotal    Decimal @db.Decimal(10, 2)

  pedido   Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  producto Producto @relation(fields: [productoId], references: [id])
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────
enum EstadoPedido {
  PENDIENTE    // Recibido, en espera de preparación
  CONFIRMADO   // Aprobado por el admin
  CANCELADO    // Rechazado o cancelado por el empleado
  PAGADO       // Marcado como pagado (para control interno, no implica proceso de pago real)
}
